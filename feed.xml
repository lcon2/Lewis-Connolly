---
layout: null
permalink: /feed.xml
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.title | xml_escape }}</title>
  <subtitle>{{ site.description | strip_html | strip_newlines | xml_escape }}</subtitle>
  <link href="{{ '/feed.xml' | absolute_url }}" rel="self" type="application/atom+xml"/>
  <link href="{{ '/' | absolute_url }}" rel="alternate" type="text/html"/>
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <id>{{ '/feed.xml' | absolute_url }}</id>
  <author>
    <name>{{ site.title | xml_escape }}</name>
    {% if site.email %}<email>{{ site.email | xml_escape }}</email>{% endif %}
  </author>
  {% comment %}Blog posts only; never include connolly-archives pages if any ever appear in posts.{% endcomment %}
  {% for post in site.posts limit:50 %}
  {% unless post.url contains 'connolly-archives' %}
  <entry>
    <title>{{ post.title | xml_escape }}</title>
    <link href="{{ post.url | absolute_url }}" rel="alternate" type="text/html"/>
    <id>{{ post.url | absolute_url }}</id>
    <published>{{ post.date | date_to_xmlschema }}</published>
    <updated>{{ post.last_modified_at | default: post.date | date_to_xmlschema }}</updated>
    {% if post.ai_summary != blank %}
    <summary type="text">{{ post.ai_summary | strip_html | strip_newlines | truncate: 4000 | xml_escape }}</summary>
    {% else %}
    <summary type="text">{{ post.content | strip_html | strip_newlines | truncatewords: 120 | xml_escape }}</summary>
    {% endif %}
  </entry>
  {% endunless %}
  {% endfor %}
</feed>
